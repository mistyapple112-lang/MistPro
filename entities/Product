{
  "name": "Product",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Product/module name"
    },
    "description": {
      "type": "string",
      "description": "Short description of the module"
    },
    "category": {
      "type": "string",
      "enum": [
        "proxy",
        "social",
        "tool",
        "utility",
        "download"
      ],
      "description": "Category of the product"
    },
    "icon": {
      "type": "string",
      "description": "Lucide icon name"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "sort_order": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "name",
    "category"
  ]
}