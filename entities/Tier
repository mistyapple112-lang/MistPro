{
  "name": "Tier",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Tier name (e.g., Tier 1, Tier 2, etc.)"
    },
    "color": {
      "type": "string",
      "default": "green",
      "description": "Accent color for the tier"
    },
    "features": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of features included"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "sort_order": {
      "type": "number",
      "default": 0
    },
    "prices": {
      "type": "object",
      "description": "Price by duration in GBP",
      "properties": {
        "1day": {
          "type": "number"
        },
        "1week": {
          "type": "number"
        },
        "1month": {
          "type": "number"
        },
        "1year": {
          "type": "number"
        },
        "forever": {
          "type": "number"
        }
      }
    }
  },
  "required": [
    "name"
  ]
}